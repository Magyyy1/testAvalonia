<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="StudentsAvalonia.Pages.RegistPage"
        Width="450" Height="500">

    <ScrollViewer>
        <StackPanel Margin="20" Spacing="10">

            <TextBlock Text="Регистрация" FontSize="20"/>

            <TextBox x:Name="FnameBox" Watermark="Фамилия"/>
            <TextBox x:Name="NameBox" Watermark="Имя"/>
            <TextBox x:Name="PatronumicBox" Watermark="Отчество"/>

            <DatePicker x:Name="BirthPicker"/>

            <ComboBox x:Name="GroupBox"
                      SelectionChanged="GroupBox_SelectionChanged"/>

            <TextBox x:Name="SpecialityBox"
                     Watermark="Специальность"
                     IsReadOnly="True"/>

            <TextBox x:Name="LoginBox" Watermark="Логин"/>
            <TextBox x:Name="PasswordBox" Watermark="Пароль"/>

            <Button Content="Зарегистрироваться" Click="Reg_Click"/>
            <Button Content="Назад" Click="Back_Click"/>

            <TextBlock x:Name="StatusText" Foreground="DarkGreen" FontSize="14"/>

        </StackPanel>
    </ScrollViewer>
</Window>