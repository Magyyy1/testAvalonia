<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="StudentsAvalonia.Pages.HomePage"
        Width="800" Height="500">

    <Grid RowDefinitions="Auto,*">

        <StackPanel Orientation="Horizontal" Spacing="10" Margin="10">

            <Button Content="Студенты" Click="Students_Click"/>
            <Button Content="Группы" Click="Groups_Click"/>
            <Button Content="Специальности" Click="Spec_Click"/>

        </StackPanel>

        <ContentControl x:Name="MainContent" Grid.Row="1"/>

    </Grid>
</Window>