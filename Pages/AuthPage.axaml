<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="StudentsAvalonia.Pages.AuthPage"
        Width="400" Height="300">

    <StackPanel Margin="20" Spacing="10">

        <TextBlock Text="Авторизация" FontSize="20"/>

        <TextBox x:Name="LoginBox" Watermark="Логин"/>
        <TextBox x:Name="PasswordBox" Watermark="Пароль"/>

        <Button Content="Войти" Click="Login_Click"/>
        <Button Content="Регистрация" Click="Reg_Click"/>

        <TextBlock x:Name="StatusText" Foreground="Red" FontSize="14"/>

    </StackPanel>
</Window>