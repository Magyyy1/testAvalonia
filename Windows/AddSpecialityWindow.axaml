<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="StudentsAvalonia.Windows.AddSpecialityWindow"
        Width="420" Height="260"
        WindowStartupLocation="CenterOwner">

    <StackPanel Margin="20" Spacing="10">

        <TextBlock Text="Добавление специальности" FontSize="20"/>

        <TextBox x:Name="NameBox" Watermark="Название специальности"/>
        <TextBox x:Name="DescriptionBox" Watermark="Описание"/>

        <Button Content="Сохранить" Click="Save_Click"/>
        <Button Content="Закрыть" Click="Close_Click"/>

    </StackPanel>
</Window>